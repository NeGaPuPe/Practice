<Window x:Class="PracticeShopProject.Windows.InstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PracticeShopProject.Windows"
        mc:Ignorable="d"
        Height="250" Width="500" WindowStyle="None" WindowStartupLocation="CenterScreen" ContentRendered="Window_ContentRendered">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Image Source="/Resources/Icons/ShopIcon.ico" Width="40" Height="40" Margin="10 0"/>
            <TextBlock VerticalAlignment="Center" Text="Установка приложения..." FontSize="19" FontWeight="Bold"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Идёт установка приложения PracticeShop" Margin="10 30 0 0" FontSize="16"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Прогресс установки:" VerticalAlignment="Center" Margin="10 20"/>
                    <ProgressBar Height="20" Width="180" Name="Progressbar"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
